    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(to right, #006400, #FFD700);
      color: white;
      text-align: center;
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    h1 {
      font-size: 3em;
      margin-bottom: 0.5em;
    }
    p {
      font-size: 1.2em;
